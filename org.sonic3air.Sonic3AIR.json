{
    "app-id" : "org.sonic3air.Sonic3AIR",
    "runtime" : "org.freedesktop.Platform",
    "runtime-version" : "25.08",
    "sdk" : "org.freedesktop.Sdk",
    "command" : "sonic3air",
    "finish-args" : [
        "--share=ipc",
        "--share=network",
        "--socket=pulseaudio",
        "--socket=x11",
        "--device=all",
        "--filesystem=~/.local/share/Steam/steamapps/common/Sega Classics/uncompressed ROMs/Sonic_Knuckles_wSonic3.bin:ro",
        "--filesystem=~/.steam/steam/steamapps/common/Sega Classics/uncompressed ROMs/Sonic_Knuckles_wSonic3.bin:ro",
        "--filesystem=~/.steam/root/steamapps/common/Sega Classics/uncompressed ROMs/Sonic_Knuckles_wSonic3.bin:ro",
        "--filesystem=~/.steam/debian-installation/steamapps/common/Sega Classics/uncompressed ROMs/Sonic_Knuckles_wSonic3.bin:ro",
        "--filesystem=~/Steam/steamapps/common/Sega Classics/uncompressed ROMs/Sonic_Knuckles_wSonic3.bin:ro",
        "--filesystem=~/.var/app/com.valvesoftware.Steam/.local/share/Steam/steamapps/common/Sega Classics/uncompressed ROMs/Sonic_Knuckles_wSonic3.bin:ro"
    ],
    "cleanup" : [
        "/include"
    ],
    "modules" : [
        {
            "name" : "sonic3air",
            "buildsystem": "simple",
            "build-commands": [
                "install -Dm755 sonic3air_linux -t /app/bin/",
                "install -Dm644 libdiscord_game_sdk.so -t /app/lib/",
                "cp -r data /app/bin",
                "install -Dm644 config.json -t /app/bin/",
                "install -Dm755 sonic3air-launcher.sh /app/bin/sonic3air",
                "install -Dm644 org.sonic3air.Sonic3AIR.desktop -t /app/share/applications/",
                "install -Dm644 org.sonic3air.Sonic3AIR.png -t /app/share/icons/hicolor/256x256/apps/",
                "install -Dm644 org.sonic3air.Sonic3AIR.metainfo.xml -t /app/share/metainfo/",
                "install -Dm644 doc/license.txt -t $FLATPAK_DEST/share/licenses/$FLATPAK_ID/sonic3air/",
                "mkdir -p $FLATPAK_DEST/share/licenses/$FLATPAK_ID/sonic3air/",
                "cp -r doc/license-thirdparty $FLATPAK_DEST/share/licenses/$FLATPAK_ID/sonic3air/"
            ],
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://github.com/Eukaryot/sonic3air/releases/download/v26.03.28.0-stable/sonic3air_game.tar.gz",
                    "sha256" : "b8e268e09eb0bd8241f9e1b75be5b1ee42b8e7f1dbcea1181e54068fe5a8d7b0"
                },
                {
                    "type" : "file",
                    "path": "sonic3air-launcher.sh"
                },
                {
                    "type" : "file",
                    "path": "data/org.sonic3air.Sonic3AIR.desktop"
                },
                {
                    "type" : "file",
                    "path": "data/org.sonic3air.Sonic3AIR.png"
                },
                {
                    "type" : "file",
                    "path": "data/org.sonic3air.Sonic3AIR.metainfo.xml"
                }
            ]
        }
    ]
}
